# Supabase — create a project at https://supabase.com, then copy these
# from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Public URL of the site (used for social share images / OG metadata).
# Locally this can stay unset; on Vercel set it to your real domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Used only by `npm run seed` (creates/syncs the COO super admin).
# Never needed in production env vars.
SEED_COO_EMAIL=coo@company.com
SEED_COO_PASSWORD=change-me-coo-1234
SEED_COO_NAME=Super Admin
